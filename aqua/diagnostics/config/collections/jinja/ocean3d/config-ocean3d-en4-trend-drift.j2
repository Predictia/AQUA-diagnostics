# Template according to #1613
# The first model in this block can be overridden
# in the command line by using:
# --model, --exp, --source, --outputdir, --catalog
datasets:
  - catalog: null
    model: FESOM
    exp: hpz3
    source: monthly-3d
    regrid: null
    reader_kwargs: {chunks: {"time": 12, "level": 1}}  # recommended for DE
    # startdate: 1990-01
    # enddate: 1990-12

output:
  outputdir: "./"
  rebuild: true
  save_netcdf: true
  save_format: ['png', 'pdf', 'svg']
  dpi: 300

diagnostics:
  ocean_drift:
    hovmoller:
      vert_coord: depth  # optional, default is 'level'
      diagnostic_name: 'ocean3d'
      run: true
      var: ['thetao', 'so']
      regions: ['go', 'io', 'ao', 'so', 'arc_o', 'po']
      dim_mean: ['lat', 'lon']

  ocean_trends:
    multilevel:
      vert_coord: depth  # optional, default is 'level'
      diagnostic_name: 'ocean3d'
      run: true
      var: ['thetao', 'so']
      regions: ['go', 'io', 'ao', 'so', 'arc_o', 'po']
      # dim_mean: ['lat']
